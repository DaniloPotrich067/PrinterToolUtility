<Window x:Class="SysLoja.PrinterTool.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SysLoja.PrinterTool.ViewModels"
        xmlns:models="clr-namespace:SysLoja.PrinterTool.Models"
        xmlns:conv="clr-namespace:SysLoja.PrinterTool.Converters"
        Title="SysLoja - Assistente de Impressao" Height="820" Width="1280"
        WindowStartupLocation="CenterScreen" Background="#0F172A"
        FontFamily="Segoe UI">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <SolidColorBrush x:Key="BgDark" Color="#0F172A" />
        <SolidColorBrush x:Key="Surface" Color="#1E293B" />
        <SolidColorBrush x:Key="Surface2" Color="#273449" />
        <SolidColorBrush x:Key="Border" Color="#334155" />
        <SolidColorBrush x:Key="TextPrimary" Color="#E2E8F0" />
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8" />
        <SolidColorBrush x:Key="Accent" Color="#0EA5A5" />
        <SolidColorBrush x:Key="AccentHover" Color="#0C8C8C" />
        <SolidColorBrush x:Key="Success" Color="#22C55E" />
        <SolidColorBrush x:Key="Warning" Color="#F59E0B" />
        <SolidColorBrush x:Key="Danger" Color="#EF4444" />
        <SolidColorBrush x:Key="Unknown" Color="#64748B" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHover}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource Surface2}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Border}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource Danger}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DC2626" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type Border}" x:Key="StatusDot">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="CornerRadius" Value="5" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="SysLoja - Assistente de Impressao" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" />
                    <TextBlock Text="Diagnostico e correcao automatizada para os erros 0x0000005B, 0x000004F8 e 0x0000011B" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource Danger}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAdministrator}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource Success}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding IsAdministrator, StringFormat='Administrador: {0}'}" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" FontSize="12" Margin="0,0,12,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Servidor de impressao (opcional):" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" />
                </StackPanel>

                <TextBox Grid.Column="1" Text="{Binding ServerTarget, UpdateSourceTrigger=PropertyChanged}"
                         Background="{StaticResource Surface2}" Foreground="{StaticResource TextPrimary}"
                         BorderBrush="{StaticResource Border}" Padding="8" VerticalContentAlignment="Center"
                         CaretBrush="White" />

                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Content="Rodar Diagnostico" Style="{StaticResource SecondaryButton}" Command="{Binding RunDiagnosticCommand}" Margin="0,0,8,0" />
                    <Button Content="Aplicar Correcoes RPC (0x0000011B)" Style="{StaticResource SecondaryButton}" Command="{Binding ApplyRpcFixCommand}" Margin="0,0,8,0" />
                    <Button Content="Corrigir Automaticamente Tudo" Style="{StaticResource PrimaryButton}" Command="{Binding RunFullAutoFixCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Health panel -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Painel de Saude" Style="{StaticResource SectionTitle}" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding HealthItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Surface2}" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{StaticResource Unknown}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Healthy">
                                                                    <Setter Property="Fill" Value="{StaticResource Success}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Warning">
                                                                    <Setter Property="Fill" Value="{StaticResource Warning}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Problem">
                                                                    <Setter Property="Fill" Value="{StaticResource Danger}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="13" />
                                            </Grid>
                                            <TextBlock Text="{Binding Evidence}" Foreground="{StaticResource TextMuted}" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0" />
                                            <TextBlock Text="{Binding SuggestedFix}" Foreground="{StaticResource Accent}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                                       Visibility="{Binding SuggestedFix, Converter={StaticResource StringToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Right side: tabs -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <TabControl Background="Transparent" BorderThickness="0">
                    <TabItem Header="Servicos">
                        <DataGrid ItemsSource="{Binding ServiceResults}" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="{StaticResource Surface}" Foreground="{StaticResource TextPrimary}"
                                  RowBackground="{StaticResource Surface}" AlternatingRowBackground="{StaticResource Surface2}"
                                  BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource Border}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Servico" Binding="{Binding FriendlyName}" Width="180" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                                <DataGridTextColumn Header="Inicializacao" Binding="{Binding StartMode}" Width="120" />
                                <DataGridTextColumn Header="Impacto" Binding="{Binding Impact}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Impressoras">
                        <DataGrid ItemsSource="{Binding PrinterResults}" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="{StaticResource Surface}" Foreground="{StaticResource TextPrimary}"
                                  RowBackground="{StaticResource Surface}" AlternatingRowBackground="{StaticResource Surface2}"
                                  BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource Border}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="200" />
                                <DataGridTextColumn Header="Porta" Binding="{Binding PortName}" Width="120" />
                                <DataGridTextColumn Header="Driver" Binding="{Binding DriverName}" Width="200" />
                                <DataGridTextColumn Header="Jobs Travados" Binding="{Binding JobsStuck}" Width="100" />
                                <DataGridTextColumn Header="Problemas" Binding="{Binding Issues}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Rede e Firewall">
                        <StackPanel Margin="12">
                            <TextBlock Text="Resultado de Rede" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="{Binding NetworkResult.Details}" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,16" />
                            <TextBlock Text="Resultado de Firewall" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="{Binding FirewallResult.Details}" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" />
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Eventos (PrintService)">
                        <DataGrid ItemsSource="{Binding EventFindings}" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="{StaticResource Surface}" Foreground="{StaticResource TextPrimary}"
                                  RowBackground="{StaticResource Surface}" AlternatingRowBackground="{StaticResource Surface2}"
                                  BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource Border}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Data/Hora" Binding="{Binding TimeCreated}" Width="150" />
                                <DataGridTextColumn Header="Classificacao" Binding="{Binding Classification}" Width="140" />
                                <DataGridTextColumn Header="Mensagem" Binding="{Binding Message}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Correcoes Manuais">
                        <StackPanel Margin="12">
                            <TextBlock Text="Acoes pontuais (use quando o diagnostico apontar necessidade especifica)" Foreground="{StaticResource TextMuted}" Margin="0,0,0,12" TextWrapping="Wrap" />
                            <Button Content="Reiniciar Spooler com seguranca" Style="{StaticResource SecondaryButton}" Command="{Binding RestartSpoolerCommand}" Margin="0,0,0,8" HorizontalAlignment="Left" />
                            <Button Content="Limpar fila de impressao travada" Style="{StaticResource SecondaryButton}" Command="{Binding ClearQueueCommand}" Margin="0,0,0,8" HorizontalAlignment="Left" />
                            <Button Content="Verificar drivers orfaos" Style="{StaticResource SecondaryButton}" Command="{Binding CheckOrphanDriversCommand}" Margin="0,0,0,8" HorizontalAlignment="Left" />
                            <Button Content="Validar dependencias do Spooler" Style="{StaticResource SecondaryButton}" Command="{Binding CheckDependenciesCommand}" Margin="0,0,0,8" HorizontalAlignment="Left" />
                            <Button Content="Validar arquitetura de drivers" Style="{StaticResource SecondaryButton}" Command="{Binding CheckDriverArchCommand}" HorizontalAlignment="Left" />
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Log Tecnico">
                        <DockPanel Margin="12">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="Exportar Relatorio (HTML)" Style="{StaticResource SecondaryButton}" Command="{Binding ExportLogCommand}" Margin="0,0,8,0" />
                                <Button Content="Abrir Pasta de Logs" Style="{StaticResource SecondaryButton}" Command="{Binding OpenLogFolderCommand}" />
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding Log.Entries}" AutoGenerateColumns="False" IsReadOnly="True"
                                      Background="{StaticResource Surface}" Foreground="{StaticResource TextPrimary}"
                                      RowBackground="{StaticResource Surface}" AlternatingRowBackground="{StaticResource Surface2}"
                                      BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource Border}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Hora" Binding="{Binding Timestamp, StringFormat='HH:mm:ss'}" Width="80" />
                                    <DataGridTextColumn Header="Nivel" Binding="{Binding Level}" Width="80" />
                                    <DataGridTextColumn Header="Categoria" Binding="{Binding Category}" Width="100" />
                                    <DataGridTextColumn Header="Operacao" Binding="{Binding Operation}" Width="220" />
                                    <DataGridTextColumn Header="Resultado" Binding="{Binding Result}" Width="120" />
                                    <DataGridTextColumn Header="Mensagem" Binding="{Binding FriendlyMessage}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" TextWrapping="Wrap" />
                <ProgressBar Grid.Column="1" Value="{Binding Progress}" Minimum="0" Maximum="100" Height="8" VerticalAlignment="Center"
                             Background="{StaticResource Surface2}" Foreground="{StaticResource Accent}" BorderThickness="0" />
            </Grid>
        </Border>
    </Grid>
</Window>
